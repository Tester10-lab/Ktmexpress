# API Base URL — Vite injects this at build time via import.meta.env.VITE_API_URL
# Local development (used by `npm run dev`):
VITE_API_URL=http://localhost:5000/api

# Production (used by `npm run build`, set in Vercel dashboard or .env.production):
# VITE_API_URL=https://ktmexpress-backend.onrender.com/api
