# Required — set these in Render Dashboard → Environment
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/diplon_logistics
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d
NODE_ENV=production

# Optional — your Vercel frontend URL (already hardcoded in server.js but useful for custom domains)
FRONTEND_URL=https://delivery-system-sand-seven.vercel.app
