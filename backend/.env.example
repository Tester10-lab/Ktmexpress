# Server
NODE_ENV=production
PORT=5000

# Database
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ktmexpress?retryWrites=true&w=majority

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# CORS
CLIENT_URL=https://ktmexpress-frontend.onrender.com
FRONTEND_URL=https://ktmexpress-frontend.onrender.com

# Email Settings
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_EMAIL=your-smtp-email
SMTP_PASSWORD=your-smtp-password
FROM_NAME=Ktmexpress Admin
FROM_EMAIL=noreply@ktmexpress.com

# Logging
LOG_LEVEL=info
